---
import IdeLayout from '../layouts/IdeLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

interface GHRepo {
  name: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  topics: string[];
  html_url: string;
  updated_at: string;
  fork: boolean;
}

const GITHUB_USER = 'rmirsh';

let repos: GHRepo[] = [];
let fetchError = false;

try {
  const token = import.meta.env.GITHUB_TOKEN;
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github+json',
    'X-GitHub-Api-Version': '2022-11-28',
  };
  if (token) headers['Authorization'] = `Bearer ${token}`;

  const res = await fetch(
    `https://api.github.com/users/${GITHUB_USER}/repos?sort=updated&per_page=100&type=public`,
    { headers }
  );

  if (res.ok) {
    const data: GHRepo[] = await res.json();
    repos = data
      .filter(r => !r.fork)
      .sort((a, b) => b.stargazers_count - a.stargazers_count ||
                      new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

const codeLines = [
/*
  { html: '<span class="syn-comment">&lt;!-- projects.astro --&gt;</span>' },
  { html: '' },
  { html: '<span class="syn-comment">&lt;!--</span>' },
  { html: `<span class="syn-comment">  fetching repos from</span>` },
  { html: `<span class="syn-comment">  github.com/${GITHUB_USER}</span>` },
  { html: '<span class="syn-comment">  at build time</span>' },
  { html: '<span class="syn-comment">--&gt;</span>' },
  { html: '' },
  */
  { html: '<span class="syn-bracket">&lt;</span><span class="syn-tag">section</span> <span class="syn-attr">class</span><span class="syn-bracket">=</span><span class="syn-string">"projects"</span><span class="syn-bracket">&gt;</span>' },
  { html: '  <span class="syn-bracket">&lt;</span><span class="syn-tag">ul</span> <span class="syn-attr">class</span><span class="syn-bracket">=</span><span class="syn-string">"repo-list"</span><span class="syn-bracket">&gt;</span>' },
  { html: '    <span class="syn-bracket">&lt;</span><span class="syn-tag">li</span><span class="syn-bracket">&gt;</span>' },
  { html: '      <span class="syn-bracket">&lt;</span><span class="syn-tag">a</span> <span class="syn-attr">href</span><span class="syn-bracket">=</span><span class="syn-string">"..."</span><span class="syn-bracket">&gt;</span>' },
  { html: '        <span class="syn-text">repo-name</span>' },
  { html: '      <span class="syn-bracket">&lt;/</span><span class="syn-tag">a</span><span class="syn-bracket">&gt;</span>' },
  { html: '    <span class="syn-bracket">&lt;/</span><span class="syn-tag">li</span><span class="syn-bracket">&gt;</span>' },
  { html: '    <span class="syn-comment">&lt;!-- ... --&gt;</span>' },
  { html: '  <span class="syn-bracket">&lt;/</span><span class="syn-tag">ul</span><span class="syn-bracket">&gt;</span>' },
  { html: '<span class="syn-bracket">&lt;/</span><span class="syn-tag">section</span><span class="syn-bracket">&gt;</span>' },
];
---
<IdeLayout title="projects" section="projects" currentPath="/projects">
  <Fragment slot="code">
    {codeLines.map((line, i) => (
      <div class="code-line">
        <span class="line-num">{i + 1}</span>
        <span class="code-content" set:html={line.html} />
      </div>
    ))}
  </Fragment>

  <Fragment slot="content">
    <div class="display-text">
      <span class="en">projects</span>
      <span class="ru">проекты</span>
    </div>

    <div class="section-label">
      <span class="en">public repos · github.com/{GITHUB_USER}</span>
      <span class="ru">публичные репозитории · github.com/{GITHUB_USER}</span>
    </div>

    {fetchError ? (
      <p class="api-fallback">
        could not fetch repos. set <code>GITHUB_TOKEN</code> env var or rebuild.
      </p>
    ) : repos.length === 0 ? (
      <p class="api-fallback">no public repos found.</p>
    ) : (
      <div class="proj-list">
        {repos.map(repo => (
          <ProjectCard
            name={repo.name}
            description={repo.description}
            language={repo.language}
            stars={repo.stargazers_count}
            topics={repo.topics}
            url={repo.html_url}
            updatedAt={repo.updated_at}
          />
        ))}
      </div>
    )}
  </Fragment>
</IdeLayout>
