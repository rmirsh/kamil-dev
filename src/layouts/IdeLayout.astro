---
import '../styles/global.css';
import TabBar from '../components/TabBar.astro';
import StatusBar from '../components/StatusBar.astro';

interface Props {
  title: string;
  section: string;
  currentPath: string;
  description?: string;
}
const { title, section, currentPath, description = 'kamil — python backend engineer' } = Astro.props;

// ASCII art background — diagonal tile of editor chars
const CHARS = ['/', '-', '*', '+', '=', '\\'];
let ascii = '';
for (let r = 0; r < 200; r++) {
  let line = '';
  for (let c = 0; c < 400; c++) {
    line += CHARS[(r * 3 + c * 2) % CHARS.length];
  }
  ascii += line + '\n';
}
---
<!doctype html>
<html lang="en" data-theme="dark" data-lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — kamil.dev</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/k.svg" />
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      var l = localStorage.getItem('lang');
      if (t) document.documentElement.dataset.theme = t;
      if (l) document.documentElement.dataset.lang = l;
    })();
  </script>
</head>
<body>
  <div class="ide-wrap">
    <TabBar currentPath={currentPath} />
    <div class="split">
      <div class="code-panel" aria-hidden="true">
        <slot name="code" />
      </div>
      <div class="split-divider"></div>
      <div class="content-panel">
        <div class="content-wrapper">
          <div class="ascii-bg" aria-hidden="true">{ascii}</div>
          <div class="content-inner">
            <slot name="content" />
          </div>
        </div>
      </div>
    </div>
    <StatusBar section={section} />
  </div>
</body>
</html>
